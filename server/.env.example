MONGODB_URI=mongodb://127.0.0.1:27017/Healthcare
JWT_SECRET=your_jwt_secret_here
REACT_APP_URL=http://localhost:3000
EXPIRES_IN=24h
REACT_APP_URL_DOMAIN=http://localhost:3000
PORT=5001

# ========== GMAIL GUI OTP ==========
# Cach 1 (KHUYEN DUNG): App Password
# 1. Bat xac minh 2 buoc Gmail: https://myaccount.google.com/security
# 2. Tao App Password: https://myaccount.google.com/apppasswords
#    - Chon app: Mail, thiet bi: Windows Computer
#    - Copy mat khau 16 ky tu (bo dau cach)
# 3. Dien vao duoi day:
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Cach 2 (OAuth2 - neu khong dung App Password):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# REDIRECT_URI=https://developers.google.com/oauthplayground
# REFRESH_TOKEN=

# Test gui email: npm run test:email

# Google Gemini API (chatbot khách hàng)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Key riêng cho Hỏi đáp AI bác sĩ (/doctor)
DOCTOR_GEMINI_API_KEY=
DOCTOR_GEMINI_MODEL=gemini-2.5-flash-lite
